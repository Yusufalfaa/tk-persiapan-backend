// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Enums

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum NewsSectionType {
  TEXT
  IMAGE
  YOUTUBE
}

// ADMIN

model Admin {
  id Int @id @default(autoincrement())

  username     String    @unique @db.VarChar(50)
  passwordHash String    @db.VarChar(255)
  name         String    @db.VarChar(100)
  role         AdminRole @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// NEWS

model News {
  id Int @id @default(autoincrement())

  title String @db.VarChar(255)
  slug  String @unique @db.VarChar(255)

  isPublished Boolean @default(true)

  thumbnail String? @db.VarChar(500)
  excerpt   String? @db.VarChar(500)

  sections NewsSection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("news")
}

model NewsSection {
  id Int @id @default(autoincrement())

  type  NewsSectionType
  order Int             @default(0)

  // TEXT
  text String? @db.Text

  // YOUTUBE
  youtubeUrl String? @db.VarChar(500)

  // IMAGE only (1-4)
  columns Int? @db.TinyInt

  newsId Int
  news   News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  images NewsSectionImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([newsId])
  @@index([order])
  @@map("news_sections")
}

model NewsSectionImage {
  id Int @id @default(autoincrement())

  imagePath String @db.VarChar(500)

  order Int @default(0)

  sectionId Int
  section   NewsSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([sectionId])
  @@index([order])
  @@map("news_section_images")
}

// SCHOOL PROFILE

model SchoolProfile {
  id Int @id @default(autoincrement())

  name    String @db.VarChar(100)
  vision  String @db.Text
  address String @db.VarChar(500)

  latitude  Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)

  googleMapsUrl String @db.VarChar(500)

  phone String @db.VarChar(20)
  email String @db.VarChar(100)

  videoUrl String? @db.VarChar(500)

  missions Mission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("school_profile")
}

model Mission {
  id Int @id @default(autoincrement())

  content String @db.VarChar(500)
  order   Int    @default(0)

  // Single school application, always references school_profile id 1
  schoolId Int           @default(1)
  school   SchoolProfile @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_missions")
}

// TEACHER

model Teacher {
  id Int @id @default(autoincrement())

  name     String @db.VarChar(100)
  position String @db.VarChar(100)

  photoPath String? @db.VarChar(500)

  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("teachers")
}
